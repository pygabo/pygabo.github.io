---
import Base from "../layouts/Base.astro";
---

<Base title="pygabo">
  <section class="hero">
    <h1>Hola, soy Gabo</h1>
    <div class="socials">
      <a href="https://github.com/pygabo" target="_blank" rel="noopener">
        GitHub
      </a>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 2rem 0 3rem;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .socials {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .socials a {
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text-muted);
    transition:
      border-color var(--transition),
      color var(--transition);
  }

  .socials a:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }


</style>
